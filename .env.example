# Evolution API
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=your-evolution-api-key
EVOLUTION_INSTANCE_NAME=whatsapp-resume

# WhatsApp groups to monitor (comma-separated group JIDs)
# Find group JIDs via Evolution API: GET /group/fetchAllGroups/{instance}
WHATSAPP_GROUPS=120363001234567890@g.us,120363009876543210@g.us

# OpenAI
OPENAI_API_KEY=sk-xxxxx

# Email (Resend)
RESEND_API_KEY=re_xxxxx
EMAIL_FROM=resumo@drpgrowth.com
EMAIL_TO=you@yourdomain.com

# Schedule (cron expression - default: 23:00 every day)
SUMMARY_CRON=0 23 * * *

# Server
PORT=3000
